generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  oauthProvider String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  npc          Npc?
  npcRejections NpcRejection[]
}

model Npc {
  id               Int            @id @default(autoincrement())
  name             String
  approved         Boolean        @default(false)
  userId           Int            @unique
  gender           Gender
  hairColor        String
  skinColor        String
  hairOption       HairOption
  selectedCategory Category
  approvalStatus   ApprovalStatus @default(pending)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id])
  npcRejections    NpcRejection[]

  @@index([userId], map: "Npc_userId_fkey")
}

model NpcRejection {
  id         Int      @id @default(autoincrement())
  userId     Int
  npcId      Int
  reason     String   @db.Text
  rejectedAt DateTime @default(now())
  npc        Npc      @relation(fields: [npcId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([npcId])
}

enum HairOption {
  none
  bald
  buzzCut
  quiff
  bobCut
  shortStraight
  longStraight
  shortWavy
  longWavy
  shortCurly
  longCurly
  afro
  ponytail
  braids
  dreadlocks
  mohawk
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum Category {
  creation
  production
  supplies
  defense
  commerce
}

enum Gender {
  male
  female
  other
}
